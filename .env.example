# ============================================================
# Agentic DQ Observability Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Anthropic / Claude API ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Cloud Platform ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_DATASET_ID=your_source_dataset
GCP_LOCATION=US
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Dataset where DQ output tables are stored
BQ_DQ_DATASET=dq_observability

# --- Dataplex (set to false to use INFORMATION_SCHEMA fallback) ---
DATAPLEX_ENABLED=false
DATAPLEX_LOCATION=us-central1

# --- Slack Alerting ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL=#data-quality-alerts

# --- Email Alerting (SendGrid) ---
SENDGRID_API_KEY=SG...
ALERT_EMAIL_FROM=dq-alerts@yourdomain.com
ALERT_EMAIL_TO=data-team@yourdomain.com,oncall@yourdomain.com

# --- Airflow / Cloud Composer ---
AIRFLOW_WEBSERVER_URL=https://your-composer-environment.appspot.com
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=changeme
AIRFLOW_DAG_BUCKET=gs://your-composer-bucket/dags

# --- FastAPI Application ---
API_KEY=change-me-to-a-secure-random-key
API_HOST=0.0.0.0
API_PORT=8000

# --- Logging & Environment ---
LOG_LEVEL=INFO
ENVIRONMENT=development
# Options: development | staging | production

# --- OpenTelemetry ---
OTEL_SERVICE_NAME=agentic-dq-platform
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
