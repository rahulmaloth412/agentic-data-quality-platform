-- DQ Rule: Freshness / Late Arrival Check
-- Rule ID: {{ rule_id }}
-- Table: {{ project_id }}.{{ dataset_name }}.{{ table_name }}
-- Timestamp Column: {{ timestamp_column }}
-- Max Lag: {{ max_lag_hours }} hours
INSERT INTO `{{ dq_project }}.{{ dq_dataset }}.dq_results`
    (run_id, rule_id, project_id, dataset_name, table_name, column_name,
     rule_type, severity, status, observed_value, expected_value, threshold_value,
     failure_count, execution_time, execution_duration_seconds, query_executed, created_at)
WITH freshness AS (
    SELECT
        MAX(`{{ timestamp_column }}`)   AS latest_timestamp,
        TIMESTAMP_DIFF(
            CURRENT_TIMESTAMP(),
            MAX(`{{ timestamp_column }}`),
            HOUR
        )                               AS lag_hours
    FROM `{{ project_id }}.{{ dataset_name }}.{{ table_name }}`
    WHERE `{{ timestamp_column }}` IS NOT NULL
)
SELECT
    '{{ run_id }}'                                          AS run_id,
    '{{ rule_id }}'                                         AS rule_id,
    '{{ project_id }}'                                      AS project_id,
    '{{ dataset_name }}'                                    AS dataset_name,
    '{{ table_name }}'                                      AS table_name,
    '{{ timestamp_column }}'                                AS column_name,
    'freshness'                                             AS rule_type,
    '{{ severity }}'                                        AS severity,
    CASE WHEN lag_hours <= {{ max_lag_hours }}
         THEN 'PASS' ELSE 'FAIL' END                        AS status,
    CAST(lag_hours AS STRING)                               AS observed_value,
    CAST({{ max_lag_hours }} AS STRING)                     AS expected_value,
    CAST({{ max_lag_hours }} AS STRING)                     AS threshold_value,
    CASE WHEN lag_hours > {{ max_lag_hours }} THEN 1 ELSE 0 END AS failure_count,
    CURRENT_TIMESTAMP()                                     AS execution_time,
    NULL                                                    AS execution_duration_seconds,
    '{{ query_hash }}'                                      AS query_executed,
    CURRENT_TIMESTAMP()                                     AS created_at
FROM freshness;
