-- DQ Rule: Schema Drift Detection
-- Rule ID: {{ rule_id }}
-- Table: {{ project_id }}.{{ dataset_name }}.{{ table_name }}
-- Checks against baseline column list stored in DQ config
INSERT INTO `{{ dq_project }}.{{ dq_dataset }}.dq_results`
    (run_id, rule_id, project_id, dataset_name, table_name, column_name,
     rule_type, severity, status, observed_value, expected_value, threshold_value,
     failure_count, execution_time, execution_duration_seconds, query_executed, created_at)
WITH current_schema AS (
    SELECT
        column_name,
        data_type
    FROM `{{ project_id }}.{{ dataset_name }}.INFORMATION_SCHEMA.COLUMNS`
    WHERE table_name = '{{ table_name }}'
),
baseline_schema AS (
    SELECT
        JSON_VALUE(col, '$.column_name') AS column_name,
        JSON_VALUE(col, '$.data_type')   AS data_type
    FROM UNNEST(JSON_QUERY_ARRAY('{{ baseline_columns_json }}')) AS col
),
added_columns AS (
    SELECT c.column_name FROM current_schema c
    LEFT JOIN baseline_schema b ON c.column_name = b.column_name
    WHERE b.column_name IS NULL
),
removed_columns AS (
    SELECT b.column_name FROM baseline_schema b
    LEFT JOIN current_schema c ON b.column_name = c.column_name
    WHERE c.column_name IS NULL
),
type_changed AS (
    SELECT c.column_name FROM current_schema c
    JOIN baseline_schema b ON c.column_name = b.column_name
    WHERE c.data_type != b.data_type
),
drift_summary AS (
    SELECT
        (SELECT COUNT(*) FROM added_columns)   AS added_count,
        (SELECT COUNT(*) FROM removed_columns) AS removed_count,
        (SELECT COUNT(*) FROM type_changed)    AS type_change_count
)
SELECT
    @run_id                                                         AS run_id,
    '{{ rule_id }}'                                                 AS rule_id,
    '{{ project_id }}'                                              AS project_id,
    '{{ dataset_name }}'                                            AS dataset_name,
    '{{ table_name }}'                                              AS table_name,
    NULL                                                            AS column_name,
    'schema_drift'                                                  AS rule_type,
    '{{ severity }}'                                                AS severity,
    CASE WHEN (added_count + removed_count + type_change_count) = 0
         THEN 'PASS' ELSE 'FAIL' END                                AS status,
    CONCAT('added:', CAST(added_count AS STRING),
           ',removed:', CAST(removed_count AS STRING),
           ',type_changed:', CAST(type_change_count AS STRING))     AS observed_value,
    'added:0,removed:0,type_changed:0'                              AS expected_value,
    '0'                                                             AS threshold_value,
    added_count + removed_count + type_change_count                 AS failure_count,
    CURRENT_TIMESTAMP()                                             AS execution_time,
    NULL                                                            AS execution_duration_seconds,
    '{{ query_hash }}'                                              AS query_executed,
    CURRENT_TIMESTAMP()                                             AS created_at
FROM drift_summary;
